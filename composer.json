{
  "name": "rougin/weasley",
  "description": "Helpers and utilities for Slytherin.",
  "keywords": [ "helper", "utility", "slytherin" ],
  "homepage": "https://roug.in/weasley/",
  "license": "MIT",
  "authors":
  [
    {
      "email": "rougingutib@gmail.com",
      "homepage": "https://roug.in/",
      "name": "Rougin Gutib",
      "role": "Software Engineer"
    }
  ],
  "require":
  {
    "php": ">=5.3.0",
    "rougin/blueprint": "~0.7",
    "rougin/classidy": "~0.1",
    "rougin/onion": "~0.1",
    "rougin/slytherin": "~0.9",
    "rougin/valla": "~0.1",
    "vlucas/valitron": "~1.4"
  },
  "require-dev":
  {
    "phpunit/phpunit": "*",
    "sanmai/phpunit-legacy-adapter": "*",
    "rougin/ezekiel": "~0.1"
  },
  "bin":
  [
    "bin/weasley",
    "bin/weasley.php"
  ],
  "autoload":
  {
    "psr-4":
    {
      "Rougin\\Weasley\\": "src"
    }
  },
  "autoload-dev":
  {
    "psr-4":
    {
      "Rougin\\Weasley\\": "tests"
    }
  },
  "scripts":
  {
    "analyze": "phpstan analyse",
    "restyle": "php-cs-fixer fix --config=phpstyle.php",
    "test": "phpunit"
  }
}
